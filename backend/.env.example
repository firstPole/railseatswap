NODE_ENV=development
PORT=3001

# Supabase — get from supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Indian Rail API — https://indianrailapi.com
RAIL_API_KEY=your-rail-api-key
RAIL_API_BASE_URL=https://indianrailapi.com/api/v2

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate-a-long-random-string-minimum-32-chars

# CORS
FRONTEND_URL=http://localhost:5173

# Razorpay — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
